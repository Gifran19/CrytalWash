# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/CrystalWash2/CrystalWash/public

# Supabase PostgreSQL — connection pooler untuk aplikasi
DATABASE_URL="postgresql://SUPABASE_USER:SUPABASE_PASSWORD@SUPABASE_POOLER_HOST:6543/postgres?pgbouncer=true"

# Direct/session connection untuk Prisma migration
DIRECT_URL="postgresql://SUPABASE_USER:SUPABASE_PASSWORD@SUPABASE_DIRECT_HOST:5432/postgres"

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false